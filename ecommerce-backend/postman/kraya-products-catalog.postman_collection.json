{
	"info": {
		"_postman_id": "b3e34b3e-5e92-411a-965a-04b123d46779",
		"name": "Kraya Products & Catalog API",
		"description": "Comprehensive tests for the E-commerce Catalog (Products, Variants, and Images). Requires an active admin token in {{auth_token}} environment variable.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Products",
			"item": [
				{
					"name": "Create Product",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"var jsonData = pm.response.json();",
									"if(jsonData.success && jsonData.data) {",
									"    pm.environment.set(\"productId\", jsonData.data.id);",
									"    pm.test(\"Product ID saved to environment\", function () {",
									"        pm.expect(pm.environment.get(\"productId\")).to.eql(jsonData.data.id);",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"name\": \"Nike Air Max Retro\",\r\n    \"description\": \"Classic comfortable running shoes.\",\r\n    \"basePrice\": 129.99,\r\n    \"category\": \"shoes\",\r\n    \"brand\": \"Nike\",\r\n    \"gender\": \"MEN\",\r\n    \"isFeatured\": true\r\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/v1/products",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"products"
							]
						}
					}
				},
