{
  "info": {
    "_postman_id": "kraya-ecommerce-products-admin-v1",
    "name": "Kraya Ecommerce - Products & Admin API",
    "description": "Production-grade collection for Product Images management. All routes are mounted at /api/v1.\n\n**Setup:**\n1. Set `baseUrl` to your server URL.\n2. Login as ADMIN via the Auth collection and copy the JWT into `authToken`.\n3. Create a product via the existing routes and copy its ID into `testProductId`.\n\n**Flow for images:** Create a product → Upload images → Set one as primary → Delete images.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string",
      "description": "JWT token from admin login. Copy from Login response into this variable."
    },
    {
      "key": "testProductId",
      "value": "",
      "type": "string",
      "description": "A valid product ID. Create one via POST /api/v1/products first."
    },
    {
      "key": "testImageId",
      "value": "",
      "type": "string",
      "description": "Auto-populated from Upload Images response. Used for delete/primary tests."
    }
  ],
  "item": [
    {
      "name": "🖼️ Product Images",
      "item": [
        {
          "name": "Upload Images",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Images array is returned', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data).to.be.an('array');",
                  "    pm.expect(json.data.length).to.be.at.least(1);",
                  "    pm.expect(json.data[0]).to.have.property('url');",
                  "    pm.expect(json.data[0]).to.have.property('publicId');",
                  "    pm.expect(json.data[0].productId).to.eql(pm.collectionVariables.get('testProductId'));",
                  "});",
                  "",
                  "pm.test('Store first image ID for subsequent tests', () => {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('testImageId', json.data[0].id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "images",
                  "type": "file",
                  "src": "",
                  "description": "Select image files to upload (JPEG, PNG, or WebP). Max 10 files, 5MB each."
                },
                {
                  "key": "altText",
                  "value": "Product image uploaded via Postman",
                  "type": "text",
                  "description": "Optional alt text applied to all uploaded images"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/{{testProductId}}/images",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "{{testProductId}}", "images"]
            },
            "description": "Uploads one or more images for a product. Uses multipart/form-data.\n\n**Prerequisite:** testProductId must be set to a valid product ID.\n\n**Note:** The `images` field must be of type \"File\" in Postman. Click "Select Files" and pick a JPEG/PNG/WebP image."
          }
        },
        {
          "name": "Upload Images - No Files (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', () => pm.response.to.have.status(400));",
                  "pm.test('Error message about missing files', () => {",
                  "    pm.expect(pm.response.json().message).to.include('image is required');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": []
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/{{testProductId}}/images",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "{{testProductId}}", "images"]
            },
            "description": "Sends a POST with no files attached — should return 400."
          }
        },
        {
          "name": "Upload Images - Product Not Found (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404', () => pm.response.to.have.status(404));",
                  "pm.test('Product not found message', () => {",
                  "    pm.expect(pm.response.json().message).to.include('not found');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "images",
                  "type": "file",
                  "src": "",
                  "description": "Attach any small image here even though the product won't exist"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/00000000-0000-0000-0000-000000000000/images",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "00000000-0000-0000-0000-000000000000", "images"]
            },
            "description": "Validates that uploading to a non-existent product returns 404 before hitting Cloudinary.\n\n**Note:** Attach a real image file to make the request valid, but the productId is fake so the check should fail first."
          }
        },
        {
          "name": "Upload Images - Unauthorized (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401', () => pm.response.to.have.status(401));",
                  "pm.test('Auth error message', () => {",
                  "    pm.expect(pm.response.json().message).to.include('Authentication');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "images",
                  "type": "file",
                  "src": "",
                  "description": "Attach an image"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/{{testProductId}}/images",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "{{testProductId}}", "images"]
            },
            "description": "Sends a POST without auth headers — should return 401 before processing any upload."
          }
        },
        {
          "name": "Set Image as Primary",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Success message is returned', () => {",
                  "    pm.expect(pm.response.json().message).to.include('Primary image updated');",
                  "});",
                  "",
                  "pm.test('Verify by fetching product - image is primary', () => {",
                  "    pm.sendRequest({",
                  "        url: pm.collectionVariables.get('baseUrl') + '/api/v1/products/' + pm.collectionVariables.get('testProductId'),",
                  "        method: 'GET'",
                  "    }, (err, res) => {",
                  "        if (!err) {",
                  "            const product = res.json().data;",
                  "            const primaryImage = product.images.find(img => img.isPrimary);",
                  "            pm.expect(primaryImage).to.exist;",
                  "            pm.expect(primaryImage.id).to.eql(pm.collectionVariables.get('testImageId'));",
                  "        }",
                  "    });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/{{testProductId}}/images/{{testImageId}}/primary",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "{{testProductId}}", "images", "{{testImageId}}", "primary"]
            },
            "description": "Sets the uploaded image as the primary (main display) image for the product.\n\n**Prerequisite:** Upload Images must have been run first to populate testImageId."
          }
        },
        {
          "name": "Set Image as Primary - Not Found (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404', () => pm.response.to.have.status(404));",
                  "pm.test('Not found message', () => {",
                  "    pm.expect(pm.response.json().message).to.include('not found');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/{{testProductId}}/images/00000000-0000-0000-0000-000000000000/primary",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "{{testProductId}}", "images", "00000000-0000-0000-0000-000000000000", "primary"]
            },
            "description": "Validates that setting a non-existent image as primary returns 404."
          }
        },
        {
          "name": "Set Image as Primary - Wrong Product (409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404', () => pm.response.to.have.status(404));",
                  "pm.test('Not found message', () => {",
                  "    pm.expect(pm.response.json().message).to.include('not found');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/00000000-0000-0000-0000-000000000000/images/{{testImageId}}/primary",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "00000000-0000-0000-0000-000000000000", "images", "{{testImageId}}", "primary"]
            },
            "description": "Validates that setting an image as primary on a different (non-existent) product fails. The service scopes the find query by both imageId AND productId."
          }
        },
        {
          "name": "Delete Image",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Success message is returned', () => {",
                  "    pm.expect(pm.response.json().message).to.include('deleted');",
                  "});",
                  "",
                  "pm.test('Verify image is removed from product', () => {",
                  "    pm.sendRequest({",
                  "        url: pm.collectionVariables.get('baseUrl') + '/api/v1/products/' + pm.collectionVariables.get('testProductId'),",
                  "        method: 'GET'",
                  "    }, (err, res) => {",
                  "        if (!err) {",
                  "            const product = res.json().data;",
                  "            const deletedImage = product.images.find(img => img.id === pm.collectionVariables.get('testImageId'));",
                  "            pm.expect(deletedImage).to.be.undefined;",
                  "        }",
                  "    });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/{{testProductId}}/images/{{testImageId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "{{testProductId}}", "images", "{{testImageId}}"]
            },
            "description": "Deletes the image from both Cloudinary and the database.\n\n**Prerequisite:** testImageId must be set from Upload Images.\n\n**Important:** If running this after Set Image as Primary, the product would still have images (just not this one)."
          }
        },
        {
          "name": "Delete Image - Not Found (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404', () => pm.response.to.have.status(404));",
                  "pm.test('Image not found message', () => {",
                  "    pm.expect(pm.response.json().message).to.include('not found');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/{{testProductId}}/images/00000000-0000-0000-0000-000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "{{testProductId}}", "images", "00000000-0000-0000-0000-000000000000"]
            },
            "description": "Validates that deleting a non-existent image returns 404."
          }
        },
        {
          "name": "Delete Image - Unauthorized (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401', () => pm.response.to.have.status(401));",
                  "pm.test('Auth error message', () => {",
                  "    pm.expect(pm.response.json().message).to.include('Authentication');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/{{testProductId}}/images/{{testImageId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "{{testProductId}}", "images", "{{testImageId}}"]
            },
            "description": "Sends DELETE without auth — should return 401."
          }
        }
      ]
    }
  ]
}
