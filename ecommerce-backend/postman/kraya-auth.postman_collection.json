{
  "info": {
    "_postman_id": "kraya-ecommerce-auth-v1",
    "name": "Kraya Ecommerce - Auth API",
    "description": "Production-grade collection for all Kraya authentication and account management endpoints. All routes are mounted at /api/v1/auth.\n\n**Setup:** Set the `baseUrl` variable to your server URL before running.\n\n**Flow:** Register → Verify Email → Login → Use protected routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "verificationToken",
      "value": "",
      "type": "string",
      "description": "Auto-set from register response logs (check your server terminal)"
    },
    {
      "key": "passwordResetToken",
      "value": "",
      "type": "string",
      "description": "Auto-set from forgot-password response logs (check your server terminal)"
    }
  ],
  "item": [
    {
      "name": "🔐 Core Authentication",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Response has success message', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.message).to.eql('User registered successfully');",
                  "});",
                  "pm.test('User object is returned', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.user).to.have.property('id');",
                  "    pm.expect(json.user).to.have.property('email');",
                  "    pm.expect(json.user).to.not.have.property('passwordHash');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"Password@123\",\n  \"phone\": \"+919876543210\",\n  \"role\": \"CUSTOMER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Creates a new user account. Sends a verification email to the user.\n\n**Note:** Check your server terminal logs for the verification link (since SMTP may not be configured locally)."
          }
        },
        {
          "name": "Register User - Already Exists (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', () => pm.response.to.have.status(400));",
                  "pm.test('Error message is returned', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.message).to.eql('User already exists');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Validates that registering with an already-existing email returns a 400 error."
          }
        },
        {
          "name": "Register User - Validation Error (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', () => pm.response.to.have.status(400));",
                  "pm.test('Zod errors are returned', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.errors).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"email\": \"not-a-valid-email\",\n  \"password\": \"123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Tests Zod validation — short password and invalid email format should return a 400 with detailed errors."
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has JWT token', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.token).to.be.a('string');",
                  "});",
                  "pm.test('auth_token cookie is set', () => {",
                  "    pm.expect(pm.cookies.has('auth_token')).to.be.true;",
                  "});",
                  "pm.test('Sensitive data is not exposed', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.user).to.not.have.property('passwordHash');",
                  "    pm.expect(json.user).to.not.have.property('isDeleted');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Authenticates the user and sets an HttpOnly auth_token cookie. The JWT is also returned in the body for API clients.\n\n**Prerequisite:** Email must be verified first."
          }
        },
        {
          "name": "Login User - Wrong Password (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401', () => pm.response.to.have.status(401));",
                  "pm.test('Error message is returned', () => {",
                  "    pm.expect(pm.response.json().message).to.eql('Invalid password');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"WrongPassword!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User (Me)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('User data is returned', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.user).to.have.property('id');",
                  "    pm.expect(json.user).to.have.property('email');",
                  "    pm.expect(json.user).to.have.property('role');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "me"]
            },
            "description": "Returns the currently authenticated user's session data from the JWT cookie.\n\n**Prerequisite:** Must be logged in (auth_token cookie must be set)."
          }
        },
        {
          "name": "Get Current User - Unauthorized (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Cookie", "value": "", "description": "Explicitly empty cookie to simulate logged-out state" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "me"]
            },
            "description": "Verifies that protected routes return 401 without a valid auth token."
          }
        },
        {
          "name": "Logout User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Logout message is returned', () => {",
                  "    pm.expect(pm.response.json().message).to.eql('Logout successful');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "logout"]
            },
            "description": "Clears the auth_token cookie and terminates the user's session.\n\n**Prerequisite:** Must be logged in."
          }
        }
      ]
    },
    {
      "name": "📧 Email Verification",
      "item": [
        {
          "name": "Verify Email",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Email verified message', () => {",
                  "    pm.expect(pm.response.json().message).to.eql('Email verified successfully');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/verify-email?token={{verificationToken}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "verify-email"],
              "query": [
                {
                  "key": "token",
                  "value": "{{verificationToken}}",
                  "description": "Paste the token from your server terminal logs here, or set the verificationToken collection variable."
                }
              ]
            },
            "description": "Verifies the user's email using the token from the verification email link.\n\n**How to get the token:** After registering, check your server terminal for the printed verification link and copy the token query param."
          }
        },
        {
          "name": "Verify Email - Invalid Token (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401', () => pm.response.to.have.status(401));",
                  "pm.test('Error message is returned', () => {",
                  "    pm.expect(pm.response.json().message).to.eql('Invalid or expired token');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/verify-email?token=this-is-an-invalid-token-12345",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "verify-email"],
              "query": [
                { "key": "token", "value": "this-is-an-invalid-token-12345" }
              ]
            }
          }
        },
        {
          "name": "Resend Verification Email",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Success message is returned', () => {",
                  "    pm.expect(pm.response.json().message).to.eql('Verification email sent successfully');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/resend-verification-email",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "resend-verification-email"]
            },
            "description": "Resends a fresh verification email to the user. Only works if the user is not yet verified."
          }
        },
        {
          "name": "Resend Verification Email - Already Verified (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', () => pm.response.to.have.status(400));",
                  "pm.test('Already verified message', () => {",
                  "    pm.expect(pm.response.json().message).to.eql('User is already verified');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/resend-verification-email",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "resend-verification-email"]
            },
            "description": "Run this after the user is already verified to confirm the 400 guard works."
          }
        }
      ]
    },
    {
      "name": "🔑 Password Management",
      "item": [
        {
          "name": "Forgot Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Success message is returned', () => {",
                  "    pm.expect(pm.response.json().message).to.eql('Password reset email sent successfully');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "forgot-password"]
            },
            "description": "Initiates the password reset flow by sending a reset link to the user's email.\n\n**Note:** Check server terminal for the reset link/token."
          }
        },
        {
          "name": "Reset Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Success message is returned', () => {",
                  "    pm.expect(pm.response.json().message).to.eql('Password reset successful');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"NewPassword@456\",\n  \"confirmPassword\": \"NewPassword@456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/reset-password?token={{passwordResetToken}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "reset-password"],
              "query": [
                {
                  "key": "token",
                  "value": "{{passwordResetToken}}",
                  "description": "Paste the token from the forgot-password server terminal log"
                }
              ]
            },
            "description": "Resets the user's password using the token from the forgot-password email. No auth required.\n\n**Prerequisite:** Call Forgot Password first and copy the token from server logs."
          }
        },
        {
          "name": "Reset Password - Mismatch (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', () => pm.response.to.have.status(400));",
                  "pm.test('Mismatch error', () => {",
                  "    pm.expect(pm.response.json().message).to.eql('Passwords do not match');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"NewPassword@456\",\n  \"confirmPassword\": \"DifferentPassword@789\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/reset-password?token={{passwordResetToken}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "reset-password"],
              "query": [
                { "key": "token", "value": "{{passwordResetToken}}" }
              ]
            }
          }
        },
        {
          "name": "Update Password (Authenticated)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Success message is returned', () => {",
                  "    pm.expect(pm.response.json().message).to.eql('Password updated successfully');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"Password@123\",\n  \"newPassword\": \"UpdatedPassword@789\",\n  \"confirmNewPassword\": \"UpdatedPassword@789\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/update-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "update-password"]
            },
            "description": "Allows an authenticated user to change their password. Requires old password for security.\n\n**Prerequisite:** Must be logged in."
          }
        },
        {
          "name": "Update Password - Wrong Old Password (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401', () => pm.response.to.have.status(401));",
                  "pm.test('Incorrect old password error', () => {",
                  "    pm.expect(pm.response.json().message).to.eql('Incorrect old password');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"CompletelyWrongPassword!\",\n  \"newPassword\": \"UpdatedPassword@789\",\n  \"confirmNewPassword\": \"UpdatedPassword@789\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/update-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "update-password"]
            }
          }
        },
        {
          "name": "Update Password - Zod Validation (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', () => pm.response.to.have.status(400));",
                  "pm.test('Zod errors are returned', () => {",
                  "    pm.expect(pm.response.json().errors).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"123\",\n  \"newPassword\": \"abc\",\n  \"confirmNewPassword\": \"xyz\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/update-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "update-password"]
            },
            "description": "Tests Zod min-length validation — passwords shorter than 6 characters should fail."
          }
        }
      ]
    },
